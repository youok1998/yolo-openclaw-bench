FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04
WORKDIR /app
RUN apt-get update && apt-get install -y python3 python3-pip && rm -rf /var/lib/apt/lists/*
COPY worker /app/worker
RUN pip3 install --no-cache-dir ultralytics pyyaml pillow \
 && pip3 install --no-cache-dir --index-url https://download.pytorch.org/whl/cu124 torch torchvision
CMD ["python3", "worker/run_benchmark.py", "demo"]
